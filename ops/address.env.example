# VPS runtime configuration. Copy to /root/address/runtime/address.env and chmod 600.
PUBLIC_API_BASE_URL=/api
API_HOST=127.0.0.1
API_PORT=8787
ALLOWED_ORIGIN=https://YOUR_DOMAIN.example
TRUST_PROXY=true
STATIC_ROOT=/root/address/app/dist
ADDRESS_DATABASE_PATH=/root/address/data/address.sqlite
ADDRESS_DATA_ROOT=/root/address/data
ADDRESS_SYNC_CACHE_DIR=/root/address/data/staging
ADDRESS_BLACKLIST_FILE=/root/address/app/config/blacklist.txt

IP_GEOLOCATION_API_URL=https://ipwho.is/{ip}
IP_GEOLOCATION_FALLBACK_API_URL=https://ipapi.co/{ip}/json/
LIVE_API_MODES=ip-region
AMAP_API_KEY=
GEOAPIFY_API_KEY=
ONEMAP_ACCESS_TOKEN=

GOOGLE_TRANSLATION_ENABLED=false
YOUDAO_APP_KEY=
YOUDAO_APP_SECRET=
TRANSLATION_BACKFILL_ENABLED=false

ADDRESS_STORAGE_SOFT_LIMIT_BYTES=42949672960
ADDRESS_STORAGE_HARD_LIMIT_BYTES=48318382080
ADDRESS_SYNC_MAX_RECORDS_PER_SHARD=50000
ADDRESS_SYNC_RECORDS_PER_LOCALITY=64
ADDRESS_SYNC_OVERTURE_BUILDINGS=true
ADDRESS_SYNC_REQUIRE_RESIDENTIAL=true
ADDRESS_SYNC_TRANSLATION_ENABLED=false
ADDRESS_SYNC_TRANSLATION_COUNTRIES=HK
ADDRESS_SYNC_RETAIN_RAW=false
ADDRESS_SYNC_RETRY_ATTEMPTS=3
ADDRESS_SYNC_RETRY_BASE_MS=1000

SYNC_ADMIN_TOKEN=GENERATE_A_RANDOM_VALUE
SYNC_ADMIN_ORIGIN=
SYNC_CONTROL_URL=http://127.0.0.1:8791
SYNC_CONTROL_PUBLIC=false
SYNC_HOST=127.0.0.1
SYNC_PORT=8791
SYNC_STATE_DIR=/root/address/runtime/sync-control
SYNC_UTC_HOUR=3
SYNC_INITIAL_RETRY_MS=300000
SYNC_DAILY_MAX_ATTEMPTS=3
SYNC_DAILY_RETRY_MS=60000

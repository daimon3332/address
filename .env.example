PUBLIC_API_BASE_URL=/api
API_HOST=127.0.0.1
API_PORT=8787
ADDRESS_DATABASE_PATH=data/address.sqlite
STATIC_ROOT=dist
TRUST_PROXY=false
ALLOWED_ORIGIN=
IP_GEOLOCATION_API_URL=https://ipwho.is/{ip}
IP_GEOLOCATION_FALLBACK_API_URL=https://ipapi.co/{ip}/json/

# Which generate modes may call live external providers (comma list of: address,residential,ip-region).
# Modes not listed always use the local database only. Default: ip-region
LIVE_API_MODES=ip-region
AMAP_API_KEY=
GEOAPIFY_API_KEY=
ONEMAP_ACCESS_TOKEN=

# Online translation is optional. Offline pool generation works with this disabled.
GOOGLE_TRANSLATION_ENABLED=false
YOUDAO_APP_KEY=
YOUDAO_APP_SECRET=

# Optional override for the custom blacklist keyword file (default: config/blacklist.txt, hot-reloaded ~10s)
# ADDRESS_BLACKLIST_FILE=config/blacklist.txt
SYNC_CONTROL_URL=http://127.0.0.1:8791
SYNC_CONTROL_PUBLIC=false
HOT_POOL_COUNTRIES=
HOT_POOL_MIN_PER_SLOT=1
